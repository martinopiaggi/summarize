            "title": "Sources"
          },
          "type": {
            "anyOf": [
              {
                "enum": [
                  "YouTube Video",
                  "Video URL",
                  "Google Drive Video Link",
                  "Dropbox Video Link",
                  "Local File",
                  "TXT"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "YouTube Video",
            "description": "Source type for all items",
            "title": "Type"
          },
          "provider": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Provider name from config",
            "title": "Provider"
          },
          "prompt_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Summary style",
            "title": "Prompt Type"
          },
          "chunk_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Characters per chunk",
            "maximum": 500000,
            "minimum": 100,
            "title": "Chunk Size"
          },
          "parallel_calls": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Concurrent API requests",
            "maximum": 200,
            "minimum": 1,
            "title": "Parallel Calls"
          },
          "max_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Max output tokens per chunk",
            "maximum": 1000000,
            "minimum": 1,
            "title": "Max Tokens"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Caption/transcription language",
            "title": "Language"
          },
          "output_language": {
            "anyOf": [
              {
                "type": "string"
